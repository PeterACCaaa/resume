---
import ResumeChat from "@components/ResumeChat.svelte";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="简历智能问答" description="方中杰的简历智能问答助手">
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<div class="mb-6">
				<h1 class="text-2xl md:text-3xl font-bold text-90 mb-2">简历智能问答</h1>
				<p class="text-sm md:text-base text-50 leading-7">
					基于本站简历与技术文章回答问题，适合快速了解项目经历、技术栈和岗位匹配度。
				</p>
			</div>
			<ResumeChat client:only="svelte" />
		</div>
	</div>
</MainGridLayout>
